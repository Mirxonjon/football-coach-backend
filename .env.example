# Application
APP_HOST=localhost
APP_PORT=4021
CORS_DOMAINS=*

# Database
DATABASE_URL="postgresql://postgres:mirxonjon@localhost:5432/logistic_db?schema=public"

# JWT Authentication
JWT_SECRET=something-secret
# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14
# OTP settings
OTP_TTL_MINUTES=3
OTP_RESEND_WINDOW_SECONDS=60
# Password reset
RESET_TOKEN_TTL_MINUTES=15
# Registration
REGISTRATION_TOKEN_TTL_MINUTES=15

# Cloudflare R2 (S3-compatible) storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_NAME=football-coach
# Public base URL — either r2.dev public URL or a custom domain mapped to the bucket
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
