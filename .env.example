# Application
APP_HOST=localhost
APP_PORT=4021
CORS_DOMAINS=*

# Database
DATABASE_URL="postgresql://postgres:mirxonjon@localhost:5432/logistic_db?schema=public"

# JWT Authentication
JWT_SECRET=something-secret
# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14
# OTP settings
OTP_TTL_MINUTES=3
OTP_RESEND_WINDOW_SECONDS=60
# Password reset
RESET_TOKEN_TTL_MINUTES=15
# Registration
REGISTRATION_TOKEN_TTL_MINUTES=15

# Cloudflare R2 (S3-compatible) storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_NAME=football-coach
# Public base URL — either r2.dev public URL or a custom domain mapped to the bucket
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Google OAuth — separate client IDs per audience.
# WEB: regular users sign-in via /v1/auth/google (mobile/web app)
# ADMIN: admin panel sign-in via /v1/admin/google
# Each id_token's `aud` claim must match the corresponding client id.
GOOGLE_WEB_CLIENT_ID=970646431364-iplfehmvg08har2g3sjhddecj7usafod.apps.googleusercontent.com
GOOGLE_ADMIN_CLIENT_ID=970646431364-ane81ilei7637h74c0gtgf9t9ino53ki.apps.googleusercontent.com
# Backwards compatibility (used as fallback if WEB/ADMIN are not set):
# GOOGLE_CLIENT_ID=...

# Click.uz merchant credentials (card tokenisation + auto-pay).
CLICK_BASE_URL=https://api.click.uz/v2/merchant
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
